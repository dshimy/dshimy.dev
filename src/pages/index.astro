---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin-bottom: 2rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
			}
			.hero .tagline {
				font-size: 1.25rem;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			.hero .bio {
				margin-bottom: 1rem;
			}
			.hero .bio a {
				text-decoration: none;
			}
			.hero .bio a:hover {
				text-decoration: underline;
			}
			section h2 {
				margin-bottom: 1rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				margin-bottom: 1.5rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				display: block;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.25rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.25rem 0;
				line-height: 1.3;
				transition: color 0.2s ease;
			}
			.post-date {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0 0 0.5rem 0;
			}
			.post-description {
				color: rgb(var(--gray-dark));
				margin: 0;
				font-size: 0.95rem;
			}
			.view-all {
				margin-top: 1rem;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Hi, I'm Darian Shimy</h1>
				<p class="tagline">Founder & CEO of <a href="https://futurefund.com">FutureFund</a></p>
				<p class="bio">
					I build technology that helps K-12 schools raise money and engage their communities.
					I write about leadership, entrepreneurship, coaching, and the craft of building products.
				</p>
				<p class="bio">
					<a href="/about">More about me &rarr;</a>
				</p>
			</div>

			<section>
				<h2>Recent Posts</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								<p class="post-description">{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
				<p class="view-all">
					<a href="/blog">View all posts &rarr;</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
