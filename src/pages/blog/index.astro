---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			.search-container {
				margin-bottom: 1.5rem;
			}
			#search-input {
				width: 100%;
				padding: 0.75rem 1rem;
				font-family: inherit;
				font-size: 1rem;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 0.5rem;
				background: white;
				color: rgb(var(--black));
				outline: none;
				transition: border-color 0.2s ease;
			}
			#search-input:focus {
				border-color: rgb(var(--accent));
				box-shadow: 0 0 0 2px rgba(var(--accent), 0.15);
			}
			#search-input::placeholder {
				color: rgb(var(--gray));
			}
			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				border: 0;
			}
			.no-results {
				color: rgb(var(--gray));
				font-style: italic;
				margin-top: 1rem;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 0;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-bottom: 1px solid rgba(var(--gray-light), 1);
			}
			ul li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				padding: 0.75rem 0;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1rem;
				line-height: 1.4;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.875rem;
				white-space: nowrap;
			}
			ul li a:hover .title,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				ul li a {
					flex-direction: column;
					gap: 0.25rem;
				}
			}
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.5rem;
				margin-top: 2rem;
				padding: 1rem 0;
			}
			.pagination button {
				padding: 0.5rem 1rem;
				font-family: inherit;
				font-size: 0.875rem;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 0.375rem;
				background: white;
				color: rgb(var(--black));
				cursor: pointer;
				transition: 0.2s ease;
			}
			.pagination button:hover:not(:disabled) {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			.pagination button:disabled {
				opacity: 0.4;
				cursor: default;
			}
			.pagination .page-info {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0 0.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="search-container">
					<label for="search-input" class="sr-only">Search blog posts</label>
					<input type="search" id="search-input" placeholder="Search posts..." autocomplete="off" />
					<p id="no-results" style="display:none;" class="no-results">No posts found.</p>
				</div>
				<ul>
					{
						posts.map((post) => (
							<li data-title={post.data.title.toLowerCase()} data-description={(post.data.description || '').toLowerCase()}>
								<a href={`/blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<nav id="pagination" class="pagination">
					<button id="prev-btn" type="button">&larr; Prev</button>
					<span id="page-info" class="page-info"></span>
					<button id="next-btn" type="button">Next &rarr;</button>
				</nav>
			</section>
		</main>
		<script>
			const PAGE_SIZE = 20;
			const input = document.getElementById('search-input') as HTMLInputElement;
			const items = Array.from(document.querySelectorAll('ul li[data-title]')) as HTMLElement[];
			const noResults = document.getElementById('no-results')!;
			const pagination = document.getElementById('pagination')!;
			const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
			const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
			const pageInfo = document.getElementById('page-info')!;

			let currentPage = 1;
			let isSearching = false;

			function getFilteredItems(): HTMLElement[] {
				const query = input.value.toLowerCase().trim();
				if (!query) return items;
				return items.filter((li) => {
					const title = li.getAttribute('data-title') || '';
					const desc = li.getAttribute('data-description') || '';
					return title.includes(query) || desc.includes(query);
				});
			}

			function render() {
				const query = input.value.toLowerCase().trim();
				isSearching = query.length > 0;
				const filtered = getFilteredItems();
				const totalPages = Math.ceil(filtered.length / PAGE_SIZE);

				if (currentPage > totalPages) currentPage = totalPages || 1;

				// Hide all items first
				items.forEach((li) => (li.style.display = 'none'));

				if (isSearching) {
					// Show all matching items when searching (no pagination)
					filtered.forEach((li) => (li.style.display = ''));
					pagination.style.display = 'none';
				} else {
					// Paginate
					const start = (currentPage - 1) * PAGE_SIZE;
					const end = start + PAGE_SIZE;
					filtered.slice(start, end).forEach((li) => (li.style.display = ''));

					pagination.style.display = totalPages > 1 ? 'flex' : 'none';
					prevBtn.disabled = currentPage <= 1;
					nextBtn.disabled = currentPage >= totalPages;
					pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
				}

				noResults.style.display = filtered.length === 0 ? '' : 'none';
			}

			input.addEventListener('input', () => {
				currentPage = 1;
				render();
			});

			prevBtn.addEventListener('click', () => {
				if (currentPage > 1) { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
			});

			nextBtn.addEventListener('click', () => {
				const totalPages = Math.ceil(getFilteredItems().length / PAGE_SIZE);
				if (currentPage < totalPages) { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
			});

			render();
		</script>
		<Footer />
	</body>
</html>
